  <diagram id="mesh-repeat-flow" name="Mesh Repeatability Flow">
    <mxGraphModel dx="2200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="2" value="Mesh Repeatability Analysis Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="700" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="10" value="Inputs And Shared Settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="360" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="Batch Orchestration And Entry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="60" width="1330" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="Detailed Per-Subject Analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1720" height="860" as="geometry"/>
        </mxCell>

        <mxCell id="13" value="Input data and options&#xa;&#xa;- repeatability root with &lt;subject&gt;_repeatability&#xa;- subject atlas NIfTI files&#xa;- shared ROI setting&#xa;  (--roi-name and optional --roi-labels)&#xa;- optional cohort root and output dir&#xa;- optional reference repeat, atlas-dir, max-subjects&#xa;- ROI labels can be inferred from presets&#xa;  (for example ctx-lh-precentral -&gt; 1022)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="280" height="270" as="geometry"/>
        </mxCell>

        <mxCell id="20" value="Start&#xa;mesh_repeat_report.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="Parse CLI and resolve common settings&#xa;ROI labels, atlas-dir, output root,&#xa;optional cohort settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="740" y="105" width="300" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="All subjects?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1110" y="115" width="170" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="Discover all &lt;subject&gt;_repeatability studies&#xa;under the selected root" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="95" width="290" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="24" value="For each discovered subject&#xa;run the per-subject pipeline below&#xa;and collect subject-level summary rows" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1340" y="205" width="290" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="25" value="Write batch outputs&#xa;batch_summary.csv/json&#xa;batch_failures.json (if any)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1340" y="335" width="290" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="26" value="Single subject mode&#xa;pass args.subject into the&#xa;per-subject pipeline below" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="980" y="245" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="27" value="Per-subject pipeline entry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="760" y="500" width="280" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="30" value="Subject setup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="530" width="430" height="760" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="Resolve subject-specific paths&#xa;repeat root, output dir, atlas, T1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="620" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="Find repeat_### anat folders&#xa;and choose the reference repeat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="740" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="33" value="Resample the subject atlas to the reference T1 grid&#xa;and build the binary ROI mask from the selected label IDs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="850" width="350" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="Load reference labels and reference TI&#xa;Build head mask, reference hotspot,&#xa;and reference high-field mask for spatial comparisons" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="980" width="350" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="40" value="Per-repeat loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="535" y="530" width="500" height="760" as="geometry"/>
        </mxCell>
        <mxCell id="41" value="Load or create volumetric inputs&#xa;Reuse TI_Volumetric_* and ti_brain_only.nii.gz&#xa;or generate them from TI.msh when missing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="620" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="42" value="Resample repeat labels and TI&#xa;onto the shared reference T1 grid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="740" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="43" value="Compute per-repeat metrics&#xa;diff fraction, ROI and head mean/median/peak,&#xa;hotspot distance, high-field Dice, label Dice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="850" width="350" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="44" value="Write per-repeat QC figure&#xa;repeat_qc/repeat_###_roi_outline_on_ti.png" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="990" width="350" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="45" value="Accumulate repeat-level state&#xa;summary rows, TI sum, diff counts,&#xa;label presence and mesh node counts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="1100" width="350" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="50" value="Aggregation and reporting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1070" y="530" width="660" height="760" as="geometry"/>
        </mxCell>
        <mxCell id="51" value="Aggregate across repeats&#xa;mean TI map, skipped repeats, diff-frequency map,&#xa;repeatability stats, ROI QC on T1 and mean TI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1120" y="620" width="560" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="52" value="Check parameter consistency&#xa;T1/T2/segmentation hashes, settings.ini,&#xa;simulation signatures from .mat files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1120" y="750" width="560" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="53" value="Optional cohort comparison&#xa;Load region_stats_fastsurfer.csv from the cohort root&#xa;and compare within-subject repeatability to cohort spread" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="880" width="560" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="54" value="Write subject outputs&#xa;summary.csv/json&#xa;repeatability_stats.csv/json&#xa;repeatability_report.md&#xa;parameter_consistency.json&#xa;cohort_comparison.json (optional)&#xa;label_diff_frequency.nii.gz&#xa;ROI QC PNGs, repeat_qc PNGs, and plots" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="1">
